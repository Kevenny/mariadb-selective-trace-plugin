[mysqld]
# O plugin declara maturity EXPERIMENTAL; o default do servidor (gamma)
# bloquearia o load. Ambiente de teste, então liberamos.
plugin-maturity=experimental
plugin-load-add=selective_trace.so

# Configuração inicial do plugin selective_trace (ver docs/ARCHITECTURE.md)
selective_trace_enabled=ON
selective_trace_file_path=/var/lib/mysql/selective_trace.json
selective_trace_schemas_to_log=testdb
selective_trace_tables_to_log=

general_log=OFF
