# Integration tests for the selective_trace audit plugin.
#
# Covers the observable contract: dynamic sysvars, validation of the filter
# lists and command qualifiers, schema/table filtering with the FILE output,
# the fail-safe (empty filters log nothing), and password masking. Run with:
#   ./mtr --suite=selective_trace
#
# Each case uses its own log file (changing selective_trace_file_path
# reopens the writer), so cases never race on a shared handle.

--source include/not_embedded.inc

if (!$SELECTIVE_TRACE_SO) {
  --skip No SELECTIVE_TRACE plugin
}

--disable_ps2_protocol

let $MYSQLD_DATADIR= `SELECT @@datadir`;

install plugin selective_trace soname 'selective_trace';

--echo #
--echo # 1. Plugin loaded, all system variables present with defaults
--echo #
show variables like 'selective_trace%';

--echo #
--echo # 2. Filter-list validation (bad entries are rejected)
--echo #
--error ER_WRONG_VALUE_FOR_VAR
set global selective_trace_schemas_to_log= 'a.b';
--error ER_WRONG_VALUE_FOR_VAR
set global selective_trace_tables_to_log= 'nodot';
--error ER_WRONG_VALUE_FOR_VAR
set global selective_trace_tables_to_log= 'schema.table.extra';
# command qualifier with an unknown token
--error ER_WRONG_VALUE_FOR_VAR
set global selective_trace_schemas_to_log= 'db:banana';

create database sl_hot;
create database sl_cold;
create table sl_hot.t (id int primary key, v varchar(32));
create table sl_cold.t (id int primary key, v varchar(32));

--echo #
--echo # 3. Schema filter, FILE output — only the filtered schema is logged
--echo #
set global selective_trace_output= 'FILE';
set global selective_trace_file_path= 'sl_case3.json';
set global selective_trace_schemas_to_log= 'sl_hot';
set global selective_trace_tables_to_log= '';
set global selective_trace_enabled= ON;

insert into sl_hot.t values (1,'logged');
insert into sl_cold.t values (2,'not logged');
select v from sl_hot.t where id = 1;

let SEARCH_FILE= $MYSQLD_DATADIR/sl_case3.json;
--echo # sl_hot.t must appear, sl_cold.t must not
let SEARCH_PATTERN= "tables":\["sl_hot.t"\];
--source include/search_pattern_in_file.inc
let SEARCH_PATTERN= sl_cold;
--source include/search_pattern_in_file.inc

--echo #
--echo # 4. Table filter is cross-schema and command-qualified (:insert)
--echo #
set global selective_trace_enabled= OFF;
set global selective_trace_file_path= 'sl_case4.json';
set global selective_trace_schemas_to_log= '';
set global selective_trace_tables_to_log= 'sl_cold.t:insert';
set global selective_trace_enabled= ON;

insert into sl_cold.t values (3,'insert logged');
update sl_cold.t set v='update skipped' where id=3;
delete from sl_cold.t where id=2;

let SEARCH_FILE= $MYSQLD_DATADIR/sl_case4.json;
let SEARCH_PATTERN= "command":"INSERT";
--source include/search_pattern_in_file.inc
--echo # UPDATE/DELETE must be absent (qualifier is :insert only)
let SEARCH_PATTERN= "command":"UPDATE";
--source include/search_pattern_in_file.inc
let SEARCH_PATTERN= "command":"DELETE";
--source include/search_pattern_in_file.inc

--echo #
--echo # 5. Fail-safe: both filter lists empty logs nothing
--echo #
set global selective_trace_enabled= OFF;
set global selective_trace_file_path= 'sl_case5.json';
set global selective_trace_schemas_to_log= '';
set global selective_trace_tables_to_log= '';
set global selective_trace_enabled= ON;

insert into sl_hot.t values (10,'x');
select v from sl_hot.t where id = 10;

--echo # no log file is created when nothing matches
--error 1
--file_exists $MYSQLD_DATADIR/sl_case5.json

--echo #
--echo # 6. Password masking on by default (DCL secret becomes ***)
--echo #
set global selective_trace_enabled= OFF;
set global selective_trace_file_path= 'sl_case6.json';
set global selective_trace_schemas_to_log= 'sl_hot,mysql';
set global selective_trace_enabled= ON;

create user sl_user@localhost identified by 'PlaintextSecret';

let SEARCH_FILE= $MYSQLD_DATADIR/sl_case6.json;
let SEARCH_PATTERN= \*\*\*;
--source include/search_pattern_in_file.inc
--echo # the literal secret must NOT be in the log
let SEARCH_PATTERN= PlaintextSecret;
--source include/search_pattern_in_file.inc

drop user sl_user@localhost;

--echo #
--echo # 7. Clean up
--echo #
set global selective_trace_enabled= OFF;
drop database sl_hot;
drop database sl_cold;
--remove_file $MYSQLD_DATADIR/sl_case3.json
--remove_file $MYSQLD_DATADIR/sl_case4.json
--remove_file $MYSQLD_DATADIR/sl_case6.json
uninstall plugin selective_trace;
